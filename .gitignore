# ignores for building the README dir tree
.git

# editors
.vscode/
.idea/

# test
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# linter, formatter, type checker
.ruff_cache/
.pyright_cache/

# uv venv
.venv/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
poetry.lock
pipfile.lock
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
whl/
wheel/

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports (extras beyond top section)
.tox/
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

# pyenv python configuration file
.python-version

# python importtime and tuna visualizer
importtime/

# Agent-managed working memory (per qte77 convention)
MEMORY.md

# Runtime artifacts from `make run` (per-invocation per-asset KPI snapshots).
results/fundamentals_*.json
# Local-preview shuffles from `make preview_local` (the production cron writes
# these to the `data` branch via REST Git Data API, bypassing .gitignore).
results/demo/
# CNN Fear & Greed year files — production cron writes them to the `data`
# branch only. Existing tracked files on `main` are legacy; new years won't be
# accidentally committed from feature branches.
results/cnn_fg/*.json

# Claude Code sandbox bwrap phantom files
# https://github.com/anthropics/claude-code/issues/17727
/HEAD
/config
/hooks
/objects
/refs
/.bash_profile
/.bashrc
/.profile
/.zprofile
/.zshrc
/.gitconfig
/.gitmodules
/.ripgreprc
/.mcp.json
/.env
/.idea
/.vscode
